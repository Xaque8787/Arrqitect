# -----------------------------------------------------------------------
# Arrqitect — sample environment file
# Copy this to .env and fill in the values you want to change.
# -----------------------------------------------------------------------

# --- Compose directory ---
# Where Arrqitect writes managed app docker-compose files on the HOST.
# Set COMPOSE_DIR to the absolute host path you want to use.
# Example:
#   COMPOSE_DIR=/opt/docker/compose
COMPOSE_DIR=

# HOST_COMPOSE_DIR is not needed in normal use — Arrqitect auto-discovers the
# host path via docker inspect. Only set this if you have renamed the container
# away from "arrqitect", the Docker socket is not mounted, or you are running
# the app outside of Docker (e.g. directly with Python).
HOST_COMPOSE_DIR=

# --- Media directory ---
# Where your media library lives on the HOST.
# Set MEDIA_DIR to the absolute host path of your media library.
# Example:
#   MEDIA_DIR=/mnt/media
MEDIA_DIR=

# HOST_MEDIA_DIR is not needed in normal use — same auto-discovery applies as
# HOST_COMPOSE_DIR above. Set it only under the same exceptional conditions.
HOST_MEDIA_DIR=

# --- Data directory ---
# Where Arrqitect stores its own database and persistent data.
# DATA_DIR=./data

# --- Network ---
# Host port Arrqitect listens on (default 2112).
# ARRQITECT_PORT=2112

# --- Permissions ---
# User/group ID for file ownership inside the container.
# Match these to the UID/GID of the user who owns your media files.
# PUID=1000
# PGID=1000
