# -----------------------------------------------------------------------
# Arrqitect — sample environment file
# Copy this to .env and fill in the values you want to change.
# -----------------------------------------------------------------------

# --- Compose directory ---
# Where Arrqitect writes managed app docker-compose files on the HOST.
# COMPOSE_DIR  : host path bound to /compose inside the container.
# HOST_COMPOSE_DIR : must equal COMPOSE_DIR so Arrqitect writes correct
#                   absolute paths into managed compose files.
# Both must be absolute paths. If left blank, auto-discovered via docker inspect.
# Example:
#   COMPOSE_DIR=/opt/docker/compose
#   HOST_COMPOSE_DIR=/opt/docker/compose
COMPOSE_DIR=
HOST_COMPOSE_DIR=

# --- Media directory ---
# Where your media library lives on the HOST.
# MEDIA_DIR    : host path bound to /media inside the container.
# HOST_MEDIA_DIR : must equal MEDIA_DIR so templates resolve media paths correctly.
# Both must be absolute paths. If left blank, auto-discovered via docker inspect.
# Example:
#   MEDIA_DIR=/mnt/media
#   HOST_MEDIA_DIR=/mnt/media
MEDIA_DIR=
HOST_MEDIA_DIR=

# --- Data directory ---
# Where Arrqitect stores its own database and persistent data.
# DATA_DIR=./data

# --- Network ---
# Host port Arrqitect listens on (default 2112).
# ARRQITECT_PORT=2112

# --- Permissions ---
# User/group ID for file ownership inside the container.
# Match these to the UID/GID of the user who owns your media files.
# PUID=1000
# PGID=1000
