# -----------------------------------------------------------------------
# Arrqitect — sample environment file
# Copy this to .env and fill in the values marked as required.
# -----------------------------------------------------------------------

# Absolute HOST path where Arrqitect writes managed app compose files.
# Must be an absolute path (starting with /) as seen by the Docker host.
# If omitted or set to a relative path, the app auto-discovers it via docker inspect.
# Example: HOST_COMPOSE_DIR=/opt/arrqitect/compose
HOST_COMPOSE_DIR=

# Optional — override the host-side bind paths for Arrqitect's own data.
# Defaults to subdirectories next to your docker-compose.yml.
# DATA_DIR=./data
# COMPOSE_DIR=./compose
# MEDIA_DIR=./media

# Optional — host port Arrqitect listens on (default 2112).
# ARRQITECT_PORT=2112

# Optional — user/group ID used for file ownership inside the container.
# Match these to the UID/GID of the user who owns your media files.
# PUID=1000
# PGID=1000
